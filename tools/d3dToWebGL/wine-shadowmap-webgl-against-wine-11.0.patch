+                    upload_format, upload_type, upload);
+        }
+    }
+    gl_info->gl_ops.gl.p_glPixelStorei(GL_UNPACK_ALIGNMENT, 4);
+    checkGLcall("Upload WebGL texture data");
+
+    free(upload);
+    return true;
+}
