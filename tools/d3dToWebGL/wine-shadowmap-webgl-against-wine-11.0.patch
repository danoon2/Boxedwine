+static void glsl_blit_batch_flush(void)
+{
+    const struct wined3d_gl_info *gl_info;
+    BOOL drawn[GLSL_BLIT_BATCH_MAX] = {0};
+    RECT src_rects[GLSL_BLIT_BATCH_MAX];
+    RECT dst_rects[GLSL_BLIT_BATCH_MAX];
+    unsigned int i, j, group_count;
+
+    if (!glsl_blit_batch.active || !glsl_blit_batch.count)
+        return;
+
+    gl_info = glsl_blit_batch.context_gl->gl_info;
+    for (i = 0; i < glsl_blit_batch.count; ++i)
+    {
+        struct glsl_blit_batch_entry *entry = &glsl_blit_batch.entries[i];
+
+        if (drawn[i])
+            continue;
+
+        group_count = 0;
+        for (j = i; j < glsl_blit_batch.count; ++j)
+        {
+            struct glsl_blit_batch_entry *candidate = &glsl_blit_batch.entries[j];
+
+            if (drawn[j] || !glsl_blit_batch_entries_match(candidate, entry->src_texture_gl,
+                    entry->src_sub_resource_idx, entry->program,
+                    entry->use_colour_key ? &entry->colour_key : NULL))
+                continue;
+
+            src_rects[group_count] = candidate->src_rect;
+            dst_rects[group_count] = candidate->dst_rect;
+            drawn[j] = TRUE;
+            ++group_count;
+        }
