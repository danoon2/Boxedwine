+static HRESULT d3dx_frame_calculate_bounding_sphere_frame(const D3DXFRAME *frame,
+        const D3DXMATRIX *parent_transform, struct d3dx_bounding_sphere *sphere)
+{
+    const D3DXMESHCONTAINER *container;
+    D3DXMATRIX transform;
+    HRESULT hr;
+
+    D3DXMatrixMultiply(&transform, &frame->TransformationMatrix, parent_transform);
+
+    for (container = frame->pMeshContainer; container; container = container->pNextMeshContainer)
+    {
+        if (container->MeshData.Type == D3DXMESHTYPE_MESH && container->MeshData.pMesh)
+        {
+            hr = d3dx_frame_calculate_bounding_sphere_mesh((ID3DXBaseMesh *)container->MeshData.pMesh,
+                    &transform, sphere);
+            if (FAILED(hr))
+                return hr;
+        }
+        else if (container->MeshData.Type == D3DXMESHTYPE_PMESH && container->MeshData.pPMesh)
+        {
+            hr = d3dx_frame_calculate_bounding_sphere_mesh((ID3DXBaseMesh *)container->MeshData.pPMesh,
+                    &transform, sphere);
+            if (FAILED(hr))
+                return hr;
+        }
+    }
+
+    if (frame->pFrameFirstChild)
+    {
+        hr = d3dx_frame_calculate_bounding_sphere_frame(frame->pFrameFirstChild, &transform, sphere);
+        if (FAILED(hr))
+            return hr;
+    }
+
+    if (frame->pFrameSibling)
+    {
+        hr = d3dx_frame_calculate_bounding_sphere_frame(frame->pFrameSibling, parent_transform, sphere);
+        if (FAILED(hr))
+            return hr;
+    }
+
+    return D3D_OK;
+}
