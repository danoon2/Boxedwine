+static BOOL d3dx_mesh_get_position_offset(ID3DXBaseMesh *mesh, UINT *position_offset)
+{
+    D3DVERTEXELEMENT9 declaration[MAX_FVF_DECL_SIZE];
+    DWORD fvf = mesh->lpVtbl->GetFVF(mesh);
+    unsigned int i;
+
+    if (fvf)
