+
+    if (FAILED(mesh->lpVtbl->GetDeclaration(mesh, declaration)))
+        return FALSE;
+
+    for (i = 0; declaration[i].Stream != 0xff; ++i)
+    {
+        if (!declaration[i].Stream && declaration[i].Usage == D3DDECLUSAGE_POSITION
+                && declaration[i].UsageIndex == 0)
+        {
+            *position_offset = declaration[i].Offset;
+            return TRUE;
+        }
+    }
+
+    return FALSE;
+}
