+static bool wined3d_texture_preserve_webgl_compressed_sysmem(struct wined3d_texture *texture,
+        unsigned int sub_resource_idx, struct wined3d_context *context, const struct upload_bo *upload_bo,
+        const struct wined3d_box *box, unsigned int src_row_pitch, unsigned int src_slice_pitch)
+{
+    const struct wined3d_format *format = texture->resource.format;
+    unsigned int level, dst_row_pitch, dst_slice_pitch;
+    struct wined3d_bo_address dst_bo_address;
+    const BYTE *src_data = upload_bo->addr.addr;
+    BYTE *dst_data, *mapped_src = NULL;
+    unsigned int width, height, depth;
+    struct wined3d_range range;
+
+    if (!wined3d_settings.webgl || !(texture->resource.format_attrs & WINED3D_FORMAT_ATTR_COMPRESSED))
+        return false;
+
+    if (!wined3d_texture_prepare_location(texture, sub_resource_idx, context, WINED3D_LOCATION_SYSMEM))
+    {
+        WARN("Failed to prepare sysmem copy for compressed WebGL texture %p, %u.\n",
+                texture, sub_resource_idx);
+        return false;
+    }
+
+    if (upload_bo->addr.buffer_object)
+    {
+        mapped_src = wined3d_context_map_bo_address(context, (const struct wined3d_bo_address *)&upload_bo->addr,
+                src_slice_pitch * (box->back - box->front), WINED3D_MAP_READ);
+        src_data = mapped_src;
+    }
+
+    wined3d_texture_get_bo_address(texture, sub_resource_idx, &dst_bo_address, WINED3D_LOCATION_SYSMEM);
+    if (dst_bo_address.buffer_object)
+    {
+        range.offset = 0;
+        range.size = texture->sub_resources[sub_resource_idx].size;
+        dst_data = wined3d_context_map_bo_address(context, &dst_bo_address, range.size,
+                WINED3D_MAP_WRITE);
+    }
+    else
+    {
+        dst_data = dst_bo_address.addr;
+    }
+
+    level = sub_resource_idx % texture->level_count;
+    wined3d_texture_get_pitch(texture, level, &dst_row_pitch, &dst_slice_pitch);
+    if (format->attrs & WINED3D_FORMAT_ATTR_BLOCKS)
+    {
+        dst_data += box->front * dst_slice_pitch;
+        dst_data += (box->top / format->block_height) * dst_row_pitch;
+        dst_data += (box->left / format->block_width) * format->block_byte_count;
+    }
+    else
+    {
+        dst_data += box->front * dst_slice_pitch;
+        dst_data += box->top * dst_row_pitch;
+        dst_data += box->left * format->byte_count;
+    }
+
+    width = box->right - box->left;
+    height = box->bottom - box->top;
+    depth = box->back - box->front;
+    wined3d_format_copy_data(format, src_data, src_row_pitch, src_slice_pitch,
+            dst_data, dst_row_pitch, dst_slice_pitch, width, height, depth);
+
+    if (dst_bo_address.buffer_object)
+        wined3d_context_unmap_bo_address(context, &dst_bo_address, 1, &range);
+    if (upload_bo->addr.buffer_object)
+        wined3d_context_unmap_bo_address(context, (const struct wined3d_bo_address *)&upload_bo->addr, 0, NULL);
+
+    wined3d_texture_validate_location(texture, sub_resource_idx, WINED3D_LOCATION_SYSMEM);
+    return true;
+}
