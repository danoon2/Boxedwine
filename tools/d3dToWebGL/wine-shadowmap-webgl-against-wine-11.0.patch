+static uint32_t shader_glsl_hash_u32(uint32_t hash, uint32_t value)
+{
+    unsigned int i;
+
+    for (i = 0; i < sizeof(value); ++i)
+    {
+        hash ^= value & 0xff;
+        hash *= 16777619u;
+        value >>= 8;
+    }
+
+    return hash;
+}
