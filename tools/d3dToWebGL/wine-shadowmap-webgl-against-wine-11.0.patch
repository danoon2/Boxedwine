+static inline DWORD yuv_to_x8r8g8b8(BYTE y, BYTE u, BYTE v)
+{
+    int c = 298 * ((int)y - 16);
+    int d = (int)u - 128;
+    int e = (int)v - 128;
+
+    return 0xff000000u
+            | cliptobyte((c + 409 * e + 128) >> 8) << 16
+            | cliptobyte((c - 100 * d - 208 * e + 128) >> 8) << 8
+            | cliptobyte((c + 516 * d + 128) >> 8);
+}
+
+static inline WORD yuv_to_r5g6b5(BYTE y, BYTE u, BYTE v)
+{
+    int c = 298 * ((int)y - 16);
+    int d = (int)u - 128;
+    int e = (int)v - 128;
+
+    return (cliptobyte((c + 409 * e + 128) >> 8) >> 3) << 11
+            | (cliptobyte((c - 100 * d - 208 * e + 128) >> 8) >> 2) << 5
+            | (cliptobyte((c + 516 * d + 128) >> 8) >> 3);
+}
