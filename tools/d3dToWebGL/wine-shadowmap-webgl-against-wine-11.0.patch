+static HRESULT parse_animation_key_matrix(ID3DXFileData *filedata, struct d3dx_matrix_key **keys_out,
+        UINT *key_count_out)
+{
+    const BYTE *data, *ptr, *end;
+    struct d3dx_matrix_key *keys = NULL;
+    DWORD key_type, key_count;
+    SIZE_T data_size;
+    unsigned int i;
+    HRESULT hr;
+
+    *keys_out = NULL;
+    *key_count_out = 0;
+
+    if (FAILED(hr = filedata->lpVtbl->Lock(filedata, &data_size, (const void **)&data)))
+        return hr;
+
+    ptr = data;
+    end = data + data_size;
+    if (end - ptr < 2 * sizeof(DWORD))
+    {
+        hr = E_FAIL;
+        goto done;
+    }
+
+    key_type = *(const DWORD *)ptr;
+    ptr += sizeof(DWORD);
+    key_count = *(const DWORD *)ptr;
+    ptr += sizeof(DWORD);
+
+    if (key_type != 4)
+    {
+        FIXME("Animation key type %lu is not implemented.\n", key_type);
+        hr = D3D_OK;
+        goto done;
+    }
+
+    if (!key_count)
+    {
+        hr = D3D_OK;
+        goto done;
+    }
+
+    if (!(keys = calloc(key_count, sizeof(*keys))))
+    {
+        hr = E_OUTOFMEMORY;
+        goto done;
+    }
+
+    for (i = 0; i < key_count; ++i)
+    {
+        DWORD value_count;
+
+        if (end - ptr < 2 * sizeof(DWORD))
+        {
+            hr = E_FAIL;
+            goto done;
+        }
+
+        keys[i].time = *(const DWORD *)ptr;
+        ptr += sizeof(DWORD);
+        value_count = *(const DWORD *)ptr;
+        ptr += sizeof(DWORD);
+
+        if (value_count != 16 || end - ptr < value_count * sizeof(float))
+        {
+            hr = E_FAIL;
+            goto done;
+        }
+
+        memcpy(&keys[i].matrix, ptr, sizeof(keys[i].matrix));
+        ptr += value_count * sizeof(float);
+    }
+
+    *keys_out = keys;
+    *key_count_out = key_count;
+    keys = NULL;
+    hr = D3D_OK;
+
+done:
+    free(keys);
+    filedata->lpVtbl->Unlock(filedata);
+    return hr;
+}
+
+static HRESULT load_animation(ID3DXFileData *filedata, const char *set_name, ID3DXAnimationController *animation)
+{
+    struct d3dx_matrix_key *keys = NULL;
+    ID3DXFileData *child = NULL;
+    char *target_name = NULL;
+    UINT key_count = 0;
+    SIZE_T child_count;
+    HRESULT hr;
+    GUID type;
+    SIZE_T i;
+
+    if (FAILED(hr = filedata->lpVtbl->GetChildren(filedata, &child_count)))
+        return hr;
+
+    for (i = 0; i < child_count; ++i)
+    {
+        if (FAILED(hr = filedata->lpVtbl->GetChild(filedata, i, &child)))
+            goto done;
+        if (FAILED(hr = child->lpVtbl->GetType(child, &type)))
+            goto done;
+
+        if (IsEqualGUID(&type, &TID_D3DRMAnimationKey))
+        {
+            free(keys);
+            keys = NULL;
+            key_count = 0;
+            if (FAILED(hr = parse_animation_key_matrix(child, &keys, &key_count)))
+                goto done;
+        }
+        else if (child->lpVtbl->IsReference(child) && IsEqualGUID(&type, &TID_D3DRMFrame))
+        {
+            free(target_name);
+            if (FAILED(hr = filedata_get_name(child, &target_name)))
+                goto done;
+        }
+
+        IUnknown_Release(child);
+        child = NULL;
+    }
+
+    if (target_name && key_count)
+        hr = d3dx9_animation_controller_register_matrix_animation(animation, set_name, target_name, key_count, keys);
+    else
+        hr = D3D_OK;
+
+done:
+    if (child) IUnknown_Release(child);
+    free(target_name);
+    free(keys);
+    return hr;
+}
+
+static HRESULT load_animation_set(ID3DXFileData *filedata, ID3DXAnimationController *animation)
+{
+    ID3DXFileData *child = NULL;
+    char *set_name = NULL;
+    SIZE_T child_count;
+    HRESULT hr;
+    GUID type;
+    SIZE_T i;
+
+    if (FAILED(hr = filedata_get_name(filedata, &set_name)))
+        return hr;
+
+    if (FAILED(hr = filedata->lpVtbl->GetChildren(filedata, &child_count)))
+        goto done;
+
+    for (i = 0; i < child_count; ++i)
+    {
+        if (FAILED(hr = filedata->lpVtbl->GetChild(filedata, i, &child)))
+            goto done;
+        if (FAILED(hr = child->lpVtbl->GetType(child, &type)))
+            goto done;
+
+        if (IsEqualGUID(&type, &TID_D3DRMAnimation))
+            hr = load_animation(child, set_name, animation);
+
+        IUnknown_Release(child);
+        child = NULL;
+        if (FAILED(hr))
+            goto done;
+    }
+
+done:
+    if (child) IUnknown_Release(child);
+    free(set_name);
+    return hr;
+}
