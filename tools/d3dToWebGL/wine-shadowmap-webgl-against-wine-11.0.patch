+static UINT frame_count_named_matrices(const D3DXFRAME *frame)
+{
+    UINT count = 0;
+
+    while (frame)
+    {
+        if (frame->Name && frame->Name[0])
+            ++count;
+        count += frame_count_named_matrices(frame->pFrameFirstChild);
+        frame = frame->pFrameSibling;
+    }
+
+    return count;
+}
+
+static HRESULT frame_register_named_matrices(D3DXFRAME *frame, ID3DXAnimationController *animation)
+{
+    HRESULT hr;
+
+    while (frame)
+    {
+        if (frame->Name && frame->Name[0])
+        {
+            hr = animation->lpVtbl->RegisterAnimationOutput(animation, frame->Name,
+                    &frame->TransformationMatrix, NULL, NULL, NULL);
+            if (FAILED(hr))
+                return hr;
+        }
+
+        if (FAILED(hr = frame_register_named_matrices(frame->pFrameFirstChild, animation)))
+            return hr;
+        frame = frame->pFrameSibling;
+    }
+
+    return D3D_OK;
+}
