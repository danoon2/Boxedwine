+struct ddraw_profile_bucket
+{
+    ULONGLONG calls;
+    ULONGLONG total_us;
+    ULONGLONG max_us;
+    ULONGLONG pixels;
+    ULONGLONG extra0;
+    DWORD last_log;
+};
+
+static BOOL ddraw_profile_enabled(void)
+{
+    static int enabled = -1;
+    const char *value;
+
+    if (enabled == -1)
+    {
+        value = getenv("BOXEDWINE_WEBGL_PROFILE");
+        enabled = value && value[0] && strcmp(value, "0");
+    }
+
+    return enabled;
+}
+
+static ULONGLONG ddraw_profile_now_us(void)
+{
+    static LARGE_INTEGER freq;
+    LARGE_INTEGER counter;
+
+    if (!freq.QuadPart && !QueryPerformanceFrequency(&freq))
+        return GetTickCount64() * 1000;
+    if (!QueryPerformanceCounter(&counter))
+        return GetTickCount64() * 1000;
+
+    return counter.QuadPart * 1000000ull / freq.QuadPart;
+}
+
+static void ddraw_profile_record(struct ddraw_profile_bucket *bucket, const char *name,
+        ULONGLONG start_us, unsigned int pixels, unsigned int extra0)
+{
+    ULONGLONG elapsed_us;
+    DWORD now;
+
+    if (!start_us)
+        return;
+
+    elapsed_us = ddraw_profile_now_us() - start_us;
+    bucket->calls++;
+    bucket->total_us += elapsed_us;
+    if (elapsed_us > bucket->max_us)
+        bucket->max_us = elapsed_us;
+    bucket->pixels += pixels;
+    bucket->extra0 += extra0;
+
+    now = GetTickCount();
+    if (!bucket->last_log)
+        bucket->last_log = now;
+    if (now - bucket->last_log < 1000)
+        return;
+
+    fprintf(stderr, "BOXEDWINE_WEBGL_PROFILE wine.%s calls=%llu total_ms=%.3f avg_us=%llu max_us=%llu mpix=%.3f extra=%llu\n",
+            name, (unsigned long long)bucket->calls, bucket->total_us / 1000.0,
+            (unsigned long long)(bucket->total_us / (bucket->calls ? bucket->calls : 1)),
+            (unsigned long long)bucket->max_us, bucket->pixels / 1000000.0,
+            (unsigned long long)bucket->extra0);
+    bucket->calls = 0;
+    bucket->total_us = 0;
+    bucket->max_us = 0;
+    bucket->pixels = 0;
+    bucket->extra0 = 0;
+    bucket->last_log = now;
+}
