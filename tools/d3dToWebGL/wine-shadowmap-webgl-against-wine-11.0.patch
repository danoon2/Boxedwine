+    d3d_info->limits.max_clip_distances = min(d3d_info->limits.max_clip_distances, 8);
+    d3d_info->limits.sample_count = min(d3d_info->limits.sample_count, 1);
+
+    d3d_info->shader_double_precision = false;
+    d3d_info->viewport_array_index_any_shader = false;
+    d3d_info->stencil_export = false;
+    d3d_info->min_max_filtering = false;
+    d3d_info->draw_base_vertex_offset = false;
+    d3d_info->srgb_write_control = false;
+    d3d_info->clip_control = false;
+    d3d_info->scaled_resolve = false;
+    d3d_info->pbo = false;
+    d3d_info->fences = false;
+    d3d_info->persistent_map = false;
+    d3d_info->ffp_alpha_test = false;
+    d3d_info->ffp_hlsl = true;
+
+    d3d_info->feature_level = min(d3d_info->feature_level, WINED3D_FEATURE_LEVEL_9_3);
+}
+
+static void wined3d_adapter_apply_webgl_caps(struct wined3d_caps *caps)
+{
+    caps->VertexShaderVersion = min(caps->VertexShaderVersion, 3);
+    caps->PixelShaderVersion = min(caps->PixelShaderVersion, 3);
+    caps->max_feature_level = min(caps->max_feature_level, WINED3D_FEATURE_LEVEL_9_3);
+
+    caps->NumSimultaneousRTs = min(caps->NumSimultaneousRTs, 4);
+    caps->MaxTextureWidth = min(caps->MaxTextureWidth, 4096u);
+    caps->MaxTextureHeight = min(caps->MaxTextureHeight, 4096u);
+    caps->MaxTextureAspectRatio = min(caps->MaxTextureAspectRatio, 4096u);
+
+    caps->TextureAddressCaps &= ~(WINED3DPTADDRESSCAPS_BORDER | WINED3DPTADDRESSCAPS_MIRRORONCE);
+    caps->VolumeTextureAddressCaps &= ~(WINED3DPTADDRESSCAPS_BORDER | WINED3DPTADDRESSCAPS_MIRRORONCE);
+
+    caps->PrimitiveMiscCaps &= ~(WINED3DPMISCCAPS_INDEPENDENTWRITEMASKS
+            | WINED3DPMISCCAPS_MRTINDEPENDENTBITDEPTHS
+            | WINED3DPMISCCAPS_POSTBLENDSRGBCONVERT);
+
+    caps->shader_double_precision = false;
+    caps->viewport_array_index_any_shader = false;
+    caps->stencil_export = false;
+    caps->min_max_filtering = false;
+}
