+                        upload_row[x * 4 + 1] = (g * 255 + 3) / 7;
+                        upload_row[x * 4 + 2] = (b * 255 + 1) / 3;
+                        upload_row[x * 4 + 3] = v >> 8;
+                        break;
+
+                    case WINED3DFMT_B10G10R10A2_UNORM:
+                        v32 = ((const uint32_t *)src_row)[x];
+                        upload_row[x * 4 + 0] = ((((v32 >> 20) & 0x3ff) * 255) + 511) / 1023;
+                        upload_row[x * 4 + 1] = ((((v32 >> 10) & 0x3ff) * 255) + 511) / 1023;
+                        upload_row[x * 4 + 2] = (((v32 & 0x3ff) * 255) + 511) / 1023;
+                        upload_row[x * 4 + 3] = ((v32 >> 30) * 255 + 1) / 3;
+                        break;
+
+                    case WINED3DFMT_R10G10B10A2_UNORM:
+                        v32 = ((const uint32_t *)src_row)[x];
+                        upload_row[x * 4 + 0] = (((v32 & 0x3ff) * 255) + 511) / 1023;
+                        upload_row[x * 4 + 1] = ((((v32 >> 10) & 0x3ff) * 255) + 511) / 1023;
+                        upload_row[x * 4 + 2] = ((((v32 >> 20) & 0x3ff) * 255) + 511) / 1023;
+                        upload_row[x * 4 + 3] = ((v32 >> 30) * 255 + 1) / 3;
+                        break;
+
+                    case WINED3DFMT_A8_UNORM:
+                    case WINED3DFMT_L8_UNORM:
+                    case WINED3DFMT_R8_UNORM:
+                        upload_row[x] = src_row[x];
+                        break;
+
+                    case WINED3DFMT_L8A8_UNORM:
+                        upload_row[x * 2 + 0] = src_row[x * 2 + 0];
+                        upload_row[x * 2 + 1] = src_row[x * 2 + 1];
+                        break;
+
+                    default:
+                        break;
+                }
+            }
