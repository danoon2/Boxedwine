+static void d3dx9_matrix_animation_sample(const struct d3dx9_matrix_animation *animation,
+        double position_ticks, D3DXMATRIX *matrix)
+{
+    const struct d3dx_matrix_key *keys = animation->keys;
+    unsigned int lo, hi;
+    float t;
+
+    if (!animation->key_count)
+    {
+        D3DXMatrixIdentity(matrix);
+        return;
+    }
+
+    if (animation->key_count == 1 || position_ticks <= keys[0].time)
+    {
+        *matrix = keys[0].matrix;
+        return;
+    }
+
+    for (hi = 1; hi < animation->key_count; ++hi)
+    {
+        if (position_ticks <= keys[hi].time)
+            break;
+    }
+
+    if (hi == animation->key_count)
+    {
+        *matrix = keys[animation->key_count - 1].matrix;
+        return;
+    }
+
+    lo = hi - 1;
+    if (keys[hi].time == keys[lo].time)
+    {
+        *matrix = keys[hi].matrix;
+        return;
+    }
+
+    t = (float)((position_ticks - keys[lo].time) / (double)(keys[hi].time - keys[lo].time));
+    d3dx9_matrix_key_lerp(&keys[lo], &keys[hi], t, matrix);
+}
