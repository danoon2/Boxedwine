+                        upload_row[x * 4 + 0] = ((v >> 8) & 0x0f) * 17;
+                        upload_row[x * 4 + 1] = ((v >> 4) & 0x0f) * 17;
+                        upload_row[x * 4 + 2] = (v & 0x0f) * 17;
+                        upload_row[x * 4 + 3] = 0xff;
+                        break;
+
+                    case WINED3DFMT_B2G3R3A8_UNORM:
