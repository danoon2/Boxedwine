+                    src_sub_resource_idx, program, colour_key))
+    {
+        glsl_blit_batch_flush();
+        glsl_blit_batch.active = TRUE;
+        glsl_blit_batch.context_gl = context_gl;
+        glsl_blit_batch.dst_texture = dst_texture;
+        glsl_blit_batch.dst_sub_resource_idx = dst_sub_resource_idx;
+        glsl_blit_batch.dst_location = dst_location;
+        glsl_blit_batch.filter = filter;
+        glsl_blit_batch.front_buffer = front_buffer;
+        glsl_blit_batch.count = 0;
+    }
+
+    for (i = 0; i < glsl_blit_batch.count; ++i)
+    {
+        if (glsl_blit_rects_overlap(&glsl_blit_batch.entries[i].dst_rect, dst_rect))
