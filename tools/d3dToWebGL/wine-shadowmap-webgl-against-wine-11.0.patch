+#define GLSL_BLIT_BATCH_MAX 256
+
+struct glsl_blit_batch_entry
+{
+    struct wined3d_texture_gl *src_texture_gl;
+    struct glsl_blitter_program *program;
+    unsigned int src_sub_resource_idx;
+    BOOL use_colour_key;
+    struct wined3d_color_key colour_key;
+    RECT src_rect;
+    RECT dst_rect;
+};
+
+struct glsl_blit_batch
+{
+    BOOL active;
+    struct wined3d_context_gl *context_gl;
+    struct wined3d_texture *dst_texture;
+    unsigned int dst_sub_resource_idx;
+    DWORD dst_location;
+    enum wined3d_texture_filter_type filter;
+    BOOL front_buffer;
+    unsigned int count;
+    struct glsl_blit_batch_entry entries[GLSL_BLIT_BATCH_MAX];
+};
+
+static struct glsl_blit_batch glsl_blit_batch;
+
+static const char boxedwine_webgl_multisource_batch_marker[] __attribute__((used)) = "BOXEDWINE_WEBGL_MULTISOURCE_BATCH_BLITS";
+
+static BOOL glsl_blit_batch_enabled(void)
+{
+    static int enabled = -1;
+    const char *value;
+
+    if (enabled == -1)
+    {
+        value = getenv("BOXEDWINE_WEBGL_DISABLE_BATCH_BLITS");
+        enabled = wined3d_settings.webgl && (!value || !value[0] || !strcmp(value, "0"));
+    }
+
+    return enabled;
+}
+
+static void glsl_blitter_upload_colour_key(const struct wined3d_gl_info *gl_info,
+        struct glsl_blitter_program *program, const struct wined3d_format *format,
+        const struct wined3d_color_key *colour_key)
+{
+    struct wined3d_color float_key[2];
+
+    wined3d_format_get_float_color_key(format, colour_key, float_key);
+    if (!program->colour_key_valid
+            || memcmp(&program->colour_key_low, &float_key[0], sizeof(program->colour_key_low))
+            || memcmp(&program->colour_key_high, &float_key[1], sizeof(program->colour_key_high)))
+    {
+        if (program->colour_key_low_location >= 0)
+            GL_EXTCALL(glUniform4fv(program->colour_key_low_location, 1, &float_key[0].r));
+        if (program->colour_key_high_location >= 0)
+            GL_EXTCALL(glUniform4fv(program->colour_key_high_location, 1, &float_key[1].r));
+        program->colour_key_low = float_key[0];
+        program->colour_key_high = float_key[1];
+        program->colour_key_valid = TRUE;
+    }
+}
+
+static BOOL glsl_blit_batch_target_matches(struct wined3d_context_gl *context_gl,
+        struct wined3d_texture *dst_texture, unsigned int dst_sub_resource_idx,
+        DWORD dst_location, enum wined3d_texture_filter_type filter)
+{
+    return glsl_blit_batch.active
+            && glsl_blit_batch.context_gl == context_gl
+            && glsl_blit_batch.dst_texture == dst_texture
+            && glsl_blit_batch.dst_sub_resource_idx == dst_sub_resource_idx
+            && glsl_blit_batch.dst_location == dst_location
+            && glsl_blit_batch.filter == filter;
+}
+
+static BOOL glsl_blit_batch_entries_match(const struct glsl_blit_batch_entry *entry,
+        struct wined3d_texture_gl *src_texture_gl, unsigned int src_sub_resource_idx,
+        struct glsl_blitter_program *program, const struct wined3d_color_key *colour_key)
+{
+    return entry->src_texture_gl == src_texture_gl
+            && entry->src_sub_resource_idx == src_sub_resource_idx
+            && entry->program == program
+            && entry->use_colour_key == !!colour_key
+            && (!colour_key || !memcmp(&entry->colour_key, colour_key, sizeof(*colour_key)));
+}
+
+static BOOL glsl_blit_batch_multisource_enabled(void)
+{
+    static int enabled = -1;
+    const char *value;
+
+    if (enabled == -1)
+    {
+        value = getenv("BOXEDWINE_WEBGL_DISABLE_MULTISOURCE_BATCH_BLITS");
+        enabled = !value || !value[0] || !strcmp(value, "0");
+    }
+
+    return enabled;
+}
