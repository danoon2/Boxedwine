+static bool wined3d_texture_gl_readback_texture3d_webgl(struct wined3d_context_gl *context_gl,
+        struct wined3d_texture_gl *texture_gl, unsigned int level, uint32_t src_location,
+        const struct wined3d_format_gl *format_gl, unsigned int width, unsigned int height,
+        unsigned int depth, unsigned int row_pitch, unsigned int slice_pitch, uint8_t *dst)
+{
+    const struct wined3d_gl_info *gl_info = context_gl->gl_info;
+    GLuint fbo, texture_name;
+    unsigned int z;
+
+    if (!gl_info->fbo_ops.glFramebufferTextureLayer)
+        return false;
+
+    texture_name = wined3d_texture_gl_get_texture_name(texture_gl, &context_gl->c,
+            src_location == WINED3D_LOCATION_TEXTURE_SRGB);
+
+    gl_info->fbo_ops.glGenFramebuffers(1, &fbo);
+    checkGLcall("glGenFramebuffers");
+    gl_info->fbo_ops.glBindFramebuffer(GL_READ_FRAMEBUFFER, fbo);
+    context_gl->fbo_read_binding = fbo;
+    context_gl->current_fbo = NULL;
+    checkGLcall("glBindFramebuffer");
+
+    gl_info->gl_ops.gl.p_glReadBuffer(GL_COLOR_ATTACHMENT0);
+    checkGLcall("glReadBuffer");
+
+    for (z = 0; z < depth; ++z)
+    {
+        uint8_t *slice = dst + z * slice_pitch;
+
+        gl_info->fbo_ops.glFramebufferTextureLayer(GL_READ_FRAMEBUFFER, GL_COLOR_ATTACHMENT0,
+                texture_name, level, z);
+        checkGLcall("glFramebufferTextureLayer");
+        wined3d_context_gl_check_fbo_status(context_gl, GL_READ_FRAMEBUFFER);
+
+        if (!wined3d_texture_gl_read_pixels_webgl_rgba8(gl_info,
+                &format_gl->f, width, height, row_pitch, slice))
+        {
+            gl_info->gl_ops.gl.p_glReadPixels(0, 0, width, height,
+                    format_gl->format, format_gl->type, slice);
+            checkGLcall("glReadPixels");
+        }
+    }
+
+    gl_info->fbo_ops.glBindFramebuffer(GL_READ_FRAMEBUFFER, 0);
+    context_gl->fbo_read_binding = 0;
+    checkGLcall("glBindFramebuffer");
+    gl_info->fbo_ops.glDeleteFramebuffers(1, &fbo);
+    checkGLcall("glDeleteFramebuffers");
+
+    return true;
+}
