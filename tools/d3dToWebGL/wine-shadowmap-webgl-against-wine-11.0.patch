+static DWORD ddraw_overlay_blt_flags(const struct ddraw_surface *overlay, DDBLTFX *fx)
+{
+    DWORD flags = DDBLT_WAIT;
+
+    memset(fx, 0, sizeof(*fx));
+    fx->dwSize = sizeof(*fx);
+
+    if (overlay->overlay_flags & DDOVER_DDFX)
+    {
+        flags |= DDBLT_DDFX;
+        fx->dwDDFX = overlay->overlay_fx.dwDDFX;
+    }
+
+    if (overlay->overlay_flags & DDOVER_KEYDESTOVERRIDE)
+    {
+        flags |= DDBLT_KEYDESTOVERRIDE;
+        fx->ddckDestColorkey = overlay->overlay_fx.dckDestColorkey;
+    }
+    else if ((overlay->overlay_flags & DDOVER_KEYDEST)
+            && (overlay->surface_desc.dwFlags & DDSD_CKDESTOVERLAY))
+    {
+        flags |= DDBLT_KEYDESTOVERRIDE;
+        fx->ddckDestColorkey = overlay->surface_desc.ddckCKDestOverlay;
+    }
+
+    if (overlay->overlay_flags & DDOVER_KEYSRCOVERRIDE)
+    {
+        flags |= DDBLT_KEYSRCOVERRIDE;
+        fx->ddckSrcColorkey = overlay->overlay_fx.dckSrcColorkey;
+    }
+    else if ((overlay->overlay_flags & DDOVER_KEYSRC)
+            && (overlay->surface_desc.dwFlags & DDSD_CKSRCOVERLAY))
+    {
