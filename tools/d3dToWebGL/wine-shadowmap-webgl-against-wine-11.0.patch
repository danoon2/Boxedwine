+static bool wined3d_texture_gl_upload_webgl_rgba8(const struct wined3d_format *src_format,
+        GLenum target, unsigned int level, unsigned int src_row_pitch, unsigned int src_slice_pitch,
+        unsigned int dst_x, unsigned int dst_y, unsigned int dst_z, unsigned int update_w,
+        unsigned int update_h, unsigned int update_d, const BYTE *addr, const struct wined3d_gl_info *gl_info)
+{
+    unsigned int x, y, z, upload_components, upload_row_pitch;
+    GLenum upload_format, upload_type;
+    uint8_t *upload;
+
+    if (!wined3d_texture_gl_get_webgl_upload_format(src_format, &upload_format, &upload_type))
+        return false;
+
+    switch (upload_format)
+    {
+        case GL_RGB:
+            upload_components = 3;
+            break;
+        case GL_RGBA:
+            upload_components = 4;
+            break;
+        case GL_RED:
+            upload_components = 1;
+            break;
+        case GL_RG:
+            upload_components = 2;
+            break;
