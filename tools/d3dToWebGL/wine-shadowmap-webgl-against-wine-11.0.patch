+            animation->tracks[0].enable = TRUE;
+        }
+    }
+
+    matrix_animation = realloc(set->animations, (set->animation_count + 1) * sizeof(*set->animations));
+    if (!matrix_animation)
+        return E_OUTOFMEMORY;
+    set->animations = matrix_animation;
+    matrix_animation = &set->animations[set->animation_count];
+    memset(matrix_animation, 0, sizeof(*matrix_animation));
+
+    if (!(matrix_animation->name = strdup(animation_name)))
+        return E_OUTOFMEMORY;
+    if (!(matrix_animation->keys = malloc(key_count * sizeof(*matrix_animation->keys))))
+    {
+        free(matrix_animation->name);
+        matrix_animation->name = NULL;
+        return E_OUTOFMEMORY;
+    }
+
+    memcpy(matrix_animation->keys, keys, key_count * sizeof(*matrix_animation->keys));
+    matrix_animation->key_count = key_count;
+    for (i = 0; i < key_count; ++i)
+        set->period_ticks = max(set->period_ticks, keys[i].time);
+    ++set->animation_count;
+
+    return D3D_OK;
+}
