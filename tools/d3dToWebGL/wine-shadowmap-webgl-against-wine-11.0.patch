+static BOOL ddraw_webgl_frontbuffer_update_due(struct ddraw *ddraw, const RECT *rect)
+{
+    unsigned int min_rects = ddraw_webgl_frontbuffer_present_min_rects();
+    DWORD now = GetTickCount();
