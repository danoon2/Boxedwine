+static void d3dx9_animation_controller_apply_set(struct d3dx9_animation_controller *animation,
+        const struct d3dx9_matrix_animation_set *set, double position)
+{
+    double position_ticks;
+    unsigned int i;
+
+    if (!set || !set->animation_count || !set->ticks_per_second)
+        return;
+
+    position_ticks = position * set->ticks_per_second;
+    if (set->period_ticks)
+        position_ticks = fmod(position_ticks, set->period_ticks);
+
+    for (i = 0; i < set->animation_count; ++i)
+    {
+        const struct d3dx9_matrix_animation *matrix_animation = &set->animations[i];
+        struct d3dx9_animation_output *output;
+        D3DXMATRIX matrix;
+
+        if (!(output = d3dx9_animation_controller_find_output(animation, matrix_animation->name)))
+            continue;
+
+        d3dx9_matrix_animation_sample(matrix_animation, position_ticks, &matrix);
+        if (output->matrix)
+            *output->matrix = matrix;
+        if (output->scale || output->rotation || output->translation)
+        {
+            D3DXVECTOR3 scale, translation;
+            D3DXQUATERNION rotation;
+
+            if (SUCCEEDED(D3DXMatrixDecompose(&scale, &rotation, &translation, &matrix)))
+            {
+                if (output->scale) *output->scale = scale;
+                if (output->rotation) *output->rotation = rotation;
+                if (output->translation) *output->translation = translation;
+            }
+        }
+    }
+}
