+    if (ddraw->webgl_frontbuffer_dirty_valid)
+        UnionRect(&ddraw->webgl_frontbuffer_dirty, &ddraw->webgl_frontbuffer_dirty, rect);
+    else
+    {
+        ddraw->webgl_frontbuffer_dirty = *rect;
+        ddraw->webgl_frontbuffer_dirty_valid = TRUE;
+    }
+    ++ddraw->webgl_frontbuffer_dirty_count;
+
+    if (min_rects)
+        return ddraw->webgl_frontbuffer_dirty_count >= min_rects;
+
+    if (!ddraw->webgl_last_present_time)
+        return TRUE;
+
+    if (ddraw->webgl_frontbuffer_dirty_count < 128 && now - ddraw->webgl_last_present_time >= 16)
+        return TRUE;
+
+    if (now - ddraw->webgl_last_present_time >= 33)
+        return TRUE;
+
+    return ddraw->webgl_frontbuffer_dirty_count >= 2048;
