+                    entry->src_texture_gl->t.resource.format, &entry->colour_key);
+        wined3d_context_gl_draw_shaded_quads(glsl_blit_batch.context_gl, entry->src_texture_gl,
+                entry->src_sub_resource_idx, src_rects, dst_rects, group_count, glsl_blit_batch.filter);
+    }
+
+    GL_EXTCALL(glUseProgram(0));
+    if (glsl_blit_batch.front_buffer)
+        gl_info->gl_ops.gl.p_glFlush();
+
+    glsl_blit_batch.active = FALSE;
+    glsl_blit_batch.count = 0;
+}
