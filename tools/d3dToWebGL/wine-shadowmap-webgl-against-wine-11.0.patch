+                        upload_row[x * 4 + 0] = (((v >> 10) & 0x1f) * 255 + 15) / 31;
+                        upload_row[x * 4 + 1] = (((v >> 5) & 0x1f) * 255 + 15) / 31;
+                        upload_row[x * 4 + 2] = ((v & 0x1f) * 255 + 15) / 31;
+                        upload_row[x * 4 + 3] = 0xff;
+                        break;
+
+                    case WINED3DFMT_B4G4R4A4_UNORM:
