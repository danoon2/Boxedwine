+static void convert_l8a8_to_l4a4_unorm(const BYTE *src, BYTE *dst, UINT src_row_pitch, UINT src_slice_pitch,
+        UINT dst_row_pitch, UINT dst_slice_pitch, UINT width, UINT height, UINT depth)
+{
+    unsigned int x, y, z;
+
+    for (z = 0; z < depth; ++z)
+    {
+        for (y = 0; y < height; ++y)
+        {
+            const BYTE *src_row = src + z * src_slice_pitch + y * src_row_pitch;
+            BYTE *dst_row = dst + z * dst_slice_pitch + y * dst_row_pitch;
+
+            for (x = 0; x < width; ++x)
+                dst_row[x] = (src_row[x * 2] >> 4) | (src_row[x * 2 + 1] & 0xf0);
+        }
+    }
+}
