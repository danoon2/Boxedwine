+static void wined3d_adapter_apply_webgl_d3d_info(struct wined3d_d3d_info *d3d_info)
+{
+    d3d_info->limits.vs_version = min(d3d_info->limits.vs_version, 3);
+    d3d_info->limits.ps_version = min(d3d_info->limits.ps_version, 3);
