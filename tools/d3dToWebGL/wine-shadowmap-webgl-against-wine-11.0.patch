+            glsl_blit_batch.active = TRUE;
+            glsl_blit_batch.context_gl = context_gl;
+            glsl_blit_batch.dst_texture = dst_texture;
+            glsl_blit_batch.dst_sub_resource_idx = dst_sub_resource_idx;
+            glsl_blit_batch.dst_location = dst_location;
+            glsl_blit_batch.filter = filter;
+            glsl_blit_batch.front_buffer = front_buffer;
+            glsl_blit_batch.count = 0;
+            break;
+        }
+    }
+
+    if (glsl_blit_batch.count == GLSL_BLIT_BATCH_MAX)
+    {
+        glsl_blit_batch_flush();
+        glsl_blit_batch.active = TRUE;
+        glsl_blit_batch.context_gl = context_gl;
+        glsl_blit_batch.dst_texture = dst_texture;
+        glsl_blit_batch.dst_sub_resource_idx = dst_sub_resource_idx;
+        glsl_blit_batch.dst_location = dst_location;
+        glsl_blit_batch.filter = filter;
+        glsl_blit_batch.front_buffer = front_buffer;
+        glsl_blit_batch.count = 0;
+    }
+
+    entry = &glsl_blit_batch.entries[glsl_blit_batch.count++];
+    entry->src_texture_gl = src_texture_gl;
+    entry->program = program;
+    entry->src_sub_resource_idx = src_sub_resource_idx;
+    entry->use_colour_key = !!colour_key;
+    if (colour_key)
+        entry->colour_key = *colour_key;
+    entry->src_rect = *src_rect;
+    entry->dst_rect = *dst_rect;
+
+    return TRUE;
+}
