+static HRESULT d3dx_frame_calculate_bounding_sphere_mesh(ID3DXBaseMesh *mesh,
+        const D3DXMATRIX *transform, struct d3dx_bounding_sphere *sphere)
+{
+    const BYTE *vertices;
+    D3DXVECTOR3 center;
+    FLOAT radius;
+    UINT position_offset;
+    DWORD vertex_count, stride;
+    HRESULT hr;
+
+    vertex_count = mesh->lpVtbl->GetNumVertices(mesh);
+    if (!vertex_count)
+        return D3D_OK;
+
+    stride = mesh->lpVtbl->GetNumBytesPerVertex(mesh);
+    if (!stride || !d3dx_mesh_get_position_offset(mesh, &position_offset))
+        return D3D_OK;
