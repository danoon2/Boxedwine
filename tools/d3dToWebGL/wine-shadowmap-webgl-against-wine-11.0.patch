+static FLOAT d3dx_matrix_max_scale(const D3DXMATRIX *matrix)
+{
+    FLOAT sx = sqrtf(matrix->_11 * matrix->_11 + matrix->_12 * matrix->_12 + matrix->_13 * matrix->_13);
+    FLOAT sy = sqrtf(matrix->_21 * matrix->_21 + matrix->_22 * matrix->_22 + matrix->_23 * matrix->_23);
+    FLOAT sz = sqrtf(matrix->_31 * matrix->_31 + matrix->_32 * matrix->_32 + matrix->_33 * matrix->_33);
+
+    return max(max(sx, sy), sz);
+}
+
+static void d3dx_merge_bounding_sphere(struct d3dx_bounding_sphere *dst,
+        const D3DXVECTOR3 *center, FLOAT radius)
+{
+    D3DXVECTOR3 delta;
+    FLOAT distance;
+
+    if (!dst->valid)
+    {
+        dst->center = *center;
+        dst->radius = radius;
+        dst->valid = TRUE;
+        return;
+    }
+
+    D3DXVec3Subtract(&delta, center, &dst->center);
+    distance = D3DXVec3Length(&delta);
+
+    if (dst->radius >= distance + radius)
+        return;
+    if (radius >= distance + dst->radius)
+    {
+        dst->center = *center;
+        dst->radius = radius;
+        return;
+    }
+
+    if (distance > 0.0f)
+    {
+        FLOAT new_radius = (distance + dst->radius + radius) * 0.5f;
+        FLOAT t = (new_radius - dst->radius) / distance;
+
+        dst->center.x += delta.x * t;
+        dst->center.y += delta.y * t;
+        dst->center.z += delta.z * t;
+        dst->radius = new_radius;
+    }
+    else if (radius > dst->radius)
+    {
+        dst->radius = radius;
+    }
+}
