+static HRESULT parse_fvf_data(ID3DXFileData *filedata, struct mesh_data *mesh, DWORD flags)
+{
+    const DWORD *data;
+    unsigned int tex_count, tex_coord_size, i;
+    const float *tex_data;
+    DWORD fvf, dword_count;
+    SIZE_T data_size;
+    HRESULT hr;
+
+    free(mesh->fvf_tex_coords);
+    mesh->fvf_tex_coords = NULL;
+    mesh->fvf_tex_coord_size = 0;
+
+    hr = filedata->lpVtbl->Lock(filedata, &data_size, (const void **)&data);
+    if (FAILED(hr)) return hr;
+
+    /* template FVFData {
+     *     DWORD dwFVF;
+     *     DWORD nDWords;
+     *     array DWORD data[nDWords];
+     * }
+     */
+    hr = E_FAIL;
+
+    if (data_size < 2 * sizeof(DWORD))
+    {
+        WARN("Truncated data (%Id bytes).\n", data_size);
+        goto end;
+    }
+
+    fvf = data[0];
+    dword_count = data[1];
+    if (data_size < (2 + dword_count) * sizeof(DWORD))
+    {
+        WARN("Truncated data (%Id bytes, %lu DWORDs declared).\n", data_size, dword_count);
+        goto end;
+    }
+
+    tex_count = (fvf & D3DFVF_TEXCOUNT_MASK) >> D3DFVF_TEXCOUNT_SHIFT;
+    if (fvf & ~(D3DFVF_TEXCOUNT_MASK | 0xffff0000u))
+    {
+        FIXME("Unsupported FVFData FVF %#lx.\n", fvf);
+        hr = D3D_OK;
+        goto end;
+    }
+
+    if (tex_count != 1)
+    {
+        FIXME("Unsupported FVFData texture count %u.\n", tex_count);
+        hr = D3D_OK;
+        goto end;
+    }
+
+    tex_coord_size = get_fvf_texcoord_size(fvf, 0);
+    if (!tex_coord_size || dword_count < mesh->num_vertices * tex_coord_size)
+    {
+        WARN("Invalid FVFData texture coordinate data, size %u, DWORDs %lu, vertices %u.\n",
+                tex_coord_size, dword_count, mesh->num_vertices);
+        goto end;
+    }
+
+    mesh->fvf_tex_coords = calloc(mesh->num_vertices, sizeof(*mesh->fvf_tex_coords));
+    if (!mesh->fvf_tex_coords)
+    {
+        hr = E_OUTOFMEMORY;
+        goto end;
+    }
+
+    tex_data = (const float *)(data + 2);
+    for (i = 0; i < mesh->num_vertices; ++i)
+        memcpy(&mesh->fvf_tex_coords[i], &tex_data[i * tex_coord_size], tex_coord_size * sizeof(float));
+
+    mesh->fvf &= ~(D3DFVF_TEXCOUNT_MASK | (0x3u << 16));
+    mesh->fvf |= D3DFVF_TEX1 | (fvf & (0x3u << 16));
+    mesh->fvf_tex_coord_size = tex_coord_size;
+
+    hr = D3D_OK;
+
+end:
+    filedata->lpVtbl->Unlock(filedata);
+    return hr;
+}
