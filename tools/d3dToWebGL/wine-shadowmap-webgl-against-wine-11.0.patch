+static void d3dx9_matrix_key_lerp(const struct d3dx_matrix_key *a,
+        const struct d3dx_matrix_key *b, float t, D3DXMATRIX *out)
+{
+    const float *ma = (const float *)a->matrix.m;
+    const float *mb = (const float *)b->matrix.m;
+    float *mo = (float *)out->m;
+    D3DXVECTOR3 scale_a, scale_b, scale, translation_a, translation_b, translation;
+    D3DXQUATERNION rotation_a, rotation_b, rotation;
+    unsigned int i;
+
+    if (SUCCEEDED(D3DXMatrixDecompose(&scale_a, &rotation_a, &translation_a, &a->matrix))
+            && SUCCEEDED(D3DXMatrixDecompose(&scale_b, &rotation_b, &translation_b, &b->matrix)))
+    {
+        scale.x = scale_a.x + (scale_b.x - scale_a.x) * t;
+        scale.y = scale_a.y + (scale_b.y - scale_a.y) * t;
+        scale.z = scale_a.z + (scale_b.z - scale_a.z) * t;
+        translation.x = translation_a.x + (translation_b.x - translation_a.x) * t;
+        translation.y = translation_a.y + (translation_b.y - translation_a.y) * t;
+        translation.z = translation_a.z + (translation_b.z - translation_a.z) * t;
+        D3DXQuaternionSlerp(&rotation, &rotation_a, &rotation_b, t);
+        D3DXMatrixTransformation(out, NULL, NULL, &scale, NULL, &rotation, &translation);
+        return;
+    }
+
+    for (i = 0; i < 16; ++i)
+        mo[i] = ma[i] + (mb[i] - ma[i]) * t;
+}
