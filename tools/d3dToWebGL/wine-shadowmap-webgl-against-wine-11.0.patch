+static void shader_glsl_generate_vs2_output_setup(struct wined3d_string_buffer *buffer,
+        const struct wined3d_shader *vs, BOOL per_vertex_point_size, const struct wined3d_gl_info *gl_info)
+{
+    const BOOL legacy_syntax = needs_legacy_glsl_syntax(gl_info);
+    DWORD colors_written_mask[2] = {0};
+    DWORD texcoords_written_mask[WINED3D_MAX_FFP_TEXTURES] = {0};
+    const char *semantic_name;
+    UINT semantic_idx;
+    char reg_mask[6];
