+                        upload_row[x * 4 + 1] = src_row[x * 4 + 1];
+                        upload_row[x * 4 + 2] = src_row[x * 4 + 0];
+                        upload_row[x * 4 + 3] = src_row[x * 4 + 3];
+                        break;
+
+                    case WINED3DFMT_R8G8B8X8_UNORM:
