+static bool wined3d_texture_gl_get_webgl_upload_format(const struct wined3d_format *format,
+        GLenum *gl_format, GLenum *gl_type)
+{
+    switch (format->id)
+    {
+        case WINED3DFMT_B8G8R8_UNORM:
+        case WINED3DFMT_B5G6R5_UNORM:
+            *gl_format = GL_RGB;
+            *gl_type = GL_UNSIGNED_BYTE;
+            return true;
+
+        case WINED3DFMT_B8G8R8X8_UNORM:
+        case WINED3DFMT_B8G8R8X8_UNORM_SRGB:
+        case WINED3DFMT_R8G8B8X8_UNORM:
+        case WINED3DFMT_B8G8R8A8_UNORM:
+        case WINED3DFMT_B8G8R8A8_UNORM_SRGB:
+        case WINED3DFMT_B5G5R5X1_UNORM:
+        case WINED3DFMT_B5G5R5A1_UNORM:
+        case WINED3DFMT_B4G4R4X4_UNORM:
+        case WINED3DFMT_B4G4R4A4_UNORM:
+        case WINED3DFMT_B2G3R3A8_UNORM:
+        case WINED3DFMT_B10G10R10A2_UNORM:
+        case WINED3DFMT_R10G10B10A2_UNORM:
+        case WINED3DFMT_R8G8B8A8_UNORM:
+        case WINED3DFMT_R8G8B8A8_UNORM_SRGB:
+            *gl_format = GL_RGBA;
+            *gl_type = GL_UNSIGNED_BYTE;
+            return true;
+
+        case WINED3DFMT_A8_UNORM:
+        case WINED3DFMT_L8_UNORM:
+        case WINED3DFMT_R8_UNORM:
+            *gl_format = GL_RED;
+            *gl_type = GL_UNSIGNED_BYTE;
+            return true;
+
+        case WINED3DFMT_L8A8_UNORM:
+            *gl_format = GL_RG;
+            *gl_type = GL_UNSIGNED_BYTE;
+            return true;
+
+        default:
+            return false;
+    }
+}
