+static void wined3d_format_apply_webgl_caps(struct wined3d_format *format)
+{
+    static const unsigned int fbo_caps = WINED3D_FORMAT_CAP_FBO_ATTACHABLE
+            | WINED3D_FORMAT_CAP_FBO_ATTACHABLE_SRGB;
+    static const unsigned int rt_caps = WINED3D_FORMAT_CAP_RENDERTARGET
+            | WINED3D_FORMAT_CAP_POSTPIXELSHADER_BLENDING
+            | WINED3D_FORMAT_CAP_SRGB_WRITE;
+    static const unsigned int decompressed_texture_caps = WINED3D_FORMAT_CAP_TEXTURE
+            | WINED3D_FORMAT_CAP_FILTERING
+            | WINED3D_FORMAT_CAP_POSTPIXELSHADER_BLENDING
+            | WINED3D_FORMAT_CAP_DECOMPRESS;
+    const bool color_renderable = wined3d_webgl_format_is_color_renderable(format->id);
+    const bool depth_stencil = wined3d_webgl_format_is_depth_stencil(format->id);
+
+    format_clear_caps(format, WINED3D_FORMAT_CAP_UNORDERED_ACCESS);
+
+    format->caps[WINED3D_GL_RES_TYPE_TEX_1D] = 0;
+    format->caps[WINED3D_GL_RES_TYPE_BUFFER] &= WINED3D_FORMAT_CAP_VERTEX_ATTRIBUTE
+            | WINED3D_FORMAT_CAP_INDEX_BUFFER;
+
+    if (color_renderable)
+    {
+        unsigned int caps = WINED3D_FORMAT_CAP_RENDERTARGET | WINED3D_FORMAT_CAP_FBO_ATTACHABLE;
+
+        if (wined3d_webgl_format_supports_blending(format->id))
+            caps |= WINED3D_FORMAT_CAP_POSTPIXELSHADER_BLENDING;
+
+        format->caps[WINED3D_GL_RES_TYPE_TEX_2D] |= caps;
+        format->caps[WINED3D_GL_RES_TYPE_TEX_CUBE] |= caps;
+        format->caps[WINED3D_GL_RES_TYPE_RB] |= caps;
+    }
+    else
+        format_clear_caps(format, rt_caps | WINED3D_FORMAT_CAP_FBO_ATTACHABLE_SRGB);
+
+    /* WebGL does not expose D3D-style control over sRGB framebuffer writes. */
+    format_clear_caps(format, WINED3D_FORMAT_CAP_SRGB_WRITE);
+
+    if (depth_stencil)
+    {
+        unsigned int caps = WINED3D_FORMAT_CAP_DEPTH_STENCIL | WINED3D_FORMAT_CAP_FBO_ATTACHABLE;
+
+        format->caps[WINED3D_GL_RES_TYPE_TEX_2D] |= caps;
+        format->caps[WINED3D_GL_RES_TYPE_RB] |= caps;
+    }
+    else
+        format_clear_caps(format, WINED3D_FORMAT_CAP_DEPTH_STENCIL);
+
+    if (!color_renderable && !depth_stencil)
+        format_clear_caps(format, fbo_caps);
+
+    if (wined3d_webgl_format_can_decompress(format))
+    {
+        format->caps[WINED3D_GL_RES_TYPE_TEX_2D] |= decompressed_texture_caps;
+        format->caps[WINED3D_GL_RES_TYPE_TEX_CUBE] |= decompressed_texture_caps;
+        format->caps[WINED3D_GL_RES_TYPE_TEX_3D] |= decompressed_texture_caps;
+    }
+}
+
+static void wined3d_format_gl_apply_webgl_format_info(struct wined3d_format_gl *format)
+{
+    switch (format->f.id)
+    {
+        case WINED3DFMT_B8G8R8_UNORM:
+            format->internal = GL_RGB8;
+            format->srgb_internal = GL_RGB8;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGB8;
+            format->format = GL_RGB;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        case WINED3DFMT_B8G8R8X8_UNORM:
+        case WINED3DFMT_B8G8R8X8_UNORM_SRGB:
+        case WINED3DFMT_R8G8B8X8_UNORM:
+            format->internal = GL_RGBA8;
+            format->srgb_internal = GL_RGBA8;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGBA8;
+            format->format = GL_RGBA;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        case WINED3DFMT_B8G8R8A8_UNORM:
+        case WINED3DFMT_B8G8R8A8_UNORM_SRGB:
+        case WINED3DFMT_R8G8B8A8_UNORM:
+        case WINED3DFMT_R8G8B8A8_UNORM_SRGB:
+            format->internal = GL_RGBA8;
+            format->srgb_internal = GL_RGBA8;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGBA8;
+            format->format = GL_RGBA;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        case WINED3DFMT_B10G10R10A2_UNORM:
+        case WINED3DFMT_R10G10B10A2_UNORM:
+            format->internal = GL_RGB10_A2;
+            format->srgb_internal = GL_RGB10_A2;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGB10_A2;
+            format->format = GL_RGBA;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        case WINED3DFMT_B5G6R5_UNORM:
+            format->internal = GL_RGB565;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGB565;
+            format->format = GL_RGB;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        case WINED3DFMT_B5G5R5X1_UNORM:
+        case WINED3DFMT_B5G5R5A1_UNORM:
+            format->internal = GL_RGB5_A1;
+            format->srgb_internal = GL_RGB5_A1;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGB5_A1;
+            format->format = GL_RGBA;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        case WINED3DFMT_B4G4R4X4_UNORM:
+        case WINED3DFMT_B4G4R4A4_UNORM:
+            format->internal = GL_RGBA4;
+            format->srgb_internal = GL_RGBA4;
+            if (!format->rt_internal)
+                format->rt_internal = GL_RGBA4;
+            format->format = GL_RGBA;
+            format->type = GL_UNSIGNED_BYTE;
+            break;
+
+        default:
+            break;
+    }
+
+    if (wined3d_webgl_format_is_color_renderable(format->f.id) && !format->rt_internal)
+        format->rt_internal = format->internal;
+}
+
+static void wined3d_adapter_apply_webgl_format_caps(struct wined3d_adapter *adapter)
+{
+    unsigned int count = WINED3D_FORMAT_COUNT + ARRAY_SIZE(typeless_depth_stencil_formats);
+    unsigned int i;
+
+    TRACE("Applying WebGL-compatible format caps clamp.\n");
+
+    for (i = 0; i < count; ++i)
+    {
+        wined3d_format_gl_apply_webgl_format_info(get_format_gl_by_idx(adapter, i));
+        wined3d_format_apply_webgl_caps(get_format_by_idx(adapter, i));
+    }
+}
