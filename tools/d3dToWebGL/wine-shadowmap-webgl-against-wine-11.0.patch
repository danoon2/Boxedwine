+            case WINED3DFMT_B5G5R5X1_UNORM:
+            case WINED3DFMT_B5G5R5A1_UNORM:
+                format->caps[WINED3D_GL_RES_TYPE_TEX_2D] |= WINED3D_FORMAT_CAP_GEN_MIPMAP;
+                format->caps[WINED3D_GL_RES_TYPE_TEX_CUBE] |= WINED3D_FORMAT_CAP_GEN_MIPMAP;
