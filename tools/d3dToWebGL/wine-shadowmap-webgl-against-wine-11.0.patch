+static DWORD wined3d_context_gl_read_index(const void *indices, unsigned int idx_size, unsigned int idx)
+{
+    return idx_size == 2 ? ((const WORD *)indices)[idx] : ((const DWORD *)indices)[idx];
+}
+
+static bool wined3d_context_gl_is_primitive_restart_index(DWORD idx, unsigned int idx_size)
+{
+    return (idx_size == 2 && idx == 0xffff) || (idx_size == 4 && idx == 0xffffffff);
+}
+
+static DWORD *wined3d_context_gl_build_webgl_flat_shading_indices(struct wined3d_context_gl *context_gl,
+        const struct wined3d_state *state, const void *indices, unsigned int idx_size,
+        int base_vertex_idx, unsigned int start_idx, unsigned int count, unsigned int *converted_count)
+{
+    unsigned int triangle_count, i, o = 0;
+    const BYTE *sysmem_indices;
+    DWORD *converted;
+    bool indexed = !!idx_size;
+
+    if (!state->extra_ps_args.flat_shading || base_vertex_idx < 0)
+        return NULL;
+
+    switch (state->primitive_type)
+    {
+        case WINED3D_PT_TRIANGLELIST:
+            triangle_count = count / 3;
+            break;
+
+        case WINED3D_PT_TRIANGLESTRIP:
+        case WINED3D_PT_TRIANGLEFAN:
+            if (count < 3)
+                return NULL;
+            triangle_count = count - 2;
+            break;
+
+        default:
+            return NULL;
+    }
+
+    if (!triangle_count)
+        return NULL;
+
+    if (indexed && state->index_buffer)
+    {
+        if (!(sysmem_indices = wined3d_buffer_load_sysmem(state->index_buffer, &context_gl->c)))
+            return NULL;
+        indices = sysmem_indices + state->index_offset + idx_size * start_idx;
+    }
+
+    if (!(converted = malloc(triangle_count * 3 * sizeof(*converted))))
+    {
+        ERR("Failed to allocate WebGL flat-shading index buffer.\n");
+        return NULL;
+    }
+
+    for (i = 0; i < triangle_count; ++i)
+    {
+        DWORD a, b, c;
+
+        if (!indexed)
+        {
+            if (state->primitive_type == WINED3D_PT_TRIANGLELIST)
+            {
+                a = start_idx + i * 3;
+                b = a + 1;
+                c = a + 2;
+            }
+            else if (state->primitive_type == WINED3D_PT_TRIANGLESTRIP)
+            {
+                a = start_idx + i;
+                b = a + 1;
+                c = a + 2;
+            }
+            else
+            {
+                a = start_idx;
+                b = start_idx + i + 1;
+                c = start_idx + i + 2;
+            }
+        }
+        else if (state->primitive_type == WINED3D_PT_TRIANGLELIST)
+        {
+            a = wined3d_context_gl_read_index(indices, idx_size, i * 3);
+            b = wined3d_context_gl_read_index(indices, idx_size, i * 3 + 1);
+            c = wined3d_context_gl_read_index(indices, idx_size, i * 3 + 2);
+        }
+        else if (state->primitive_type == WINED3D_PT_TRIANGLESTRIP)
+        {
+            a = wined3d_context_gl_read_index(indices, idx_size, i);
+            b = wined3d_context_gl_read_index(indices, idx_size, i + 1);
+            c = wined3d_context_gl_read_index(indices, idx_size, i + 2);
+        }
+        else
+        {
+            a = wined3d_context_gl_read_index(indices, idx_size, 0);
+            b = wined3d_context_gl_read_index(indices, idx_size, i + 1);
+            c = wined3d_context_gl_read_index(indices, idx_size, i + 2);
+        }
+
+        if (indexed && (wined3d_context_gl_is_primitive_restart_index(a, idx_size)
+                || wined3d_context_gl_is_primitive_restart_index(b, idx_size)
+                || wined3d_context_gl_is_primitive_restart_index(c, idx_size)))
+        {
+            free(converted);
+            return NULL;
+        }
+
+        a += base_vertex_idx;
+        b += base_vertex_idx;
+        c += base_vertex_idx;
+
+        if (state->primitive_type == WINED3D_PT_TRIANGLESTRIP && (i & 1))
+        {
+            converted[o++] = c;
+            converted[o++] = b;
+            converted[o++] = a;
+        }
+        else
+        {
+            converted[o++] = b;
+            converted[o++] = c;
+            converted[o++] = a;
+        }
+    }
+
+    *converted_count = o;
+    return converted;
+}
