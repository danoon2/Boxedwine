+static bool wined3d_texture_gl_read_pixels_webgl_rgba8(const struct wined3d_gl_info *gl_info,
+        const struct wined3d_format *format, unsigned int width, unsigned int height,
+        unsigned int row_pitch, uint8_t *dst)
+{
+    uint8_t *rgba;
+    unsigned int x, y, pixel_count = width * height;
+
+    switch (format->id)
+    {
+        case WINED3DFMT_B8G8R8_UNORM:
+        case WINED3DFMT_B5G6R5_UNORM:
+        case WINED3DFMT_B5G5R5X1_UNORM:
+        case WINED3DFMT_B5G5R5A1_UNORM:
+        case WINED3DFMT_B4G4R4X4_UNORM:
+        case WINED3DFMT_B4G4R4A4_UNORM:
+        case WINED3DFMT_B2G3R3A8_UNORM:
+        case WINED3DFMT_A8_UNORM:
+        case WINED3DFMT_L8_UNORM:
+        case WINED3DFMT_L8A8_UNORM:
+        case WINED3DFMT_R8_UNORM:
+        case WINED3DFMT_R16_UNORM:
+        case WINED3DFMT_B10G10R10A2_UNORM:
+        case WINED3DFMT_B8G8R8A8_UNORM:
+        case WINED3DFMT_B8G8R8A8_UNORM_SRGB:
+        case WINED3DFMT_B8G8R8X8_UNORM:
+        case WINED3DFMT_B8G8R8X8_UNORM_SRGB:
+        case WINED3DFMT_R10G10B10A2_UNORM:
+        case WINED3DFMT_R8G8B8A8_UNORM:
+        case WINED3DFMT_R8G8B8A8_UNORM_SRGB:
+        case WINED3DFMT_R8G8B8X8_UNORM:
+            break;
+
+        default:
+            return false;
+    }
+
+    if (!(rgba = malloc(pixel_count * 4)))
+    {
+        ERR("Failed to allocate readback memory.\n");
+        return false;
+    }
+
+    gl_info->gl_ops.gl.p_glReadPixels(0, 0, width, height, GL_RGBA, GL_UNSIGNED_BYTE, rgba);
+    for (y = 0; y < height; ++y)
+    {
+        uint8_t *dst_row = dst + y * row_pitch;
+        const uint8_t *src_row = rgba + y * width * 4;
+
+        for (x = 0; x < width; ++x)
+        {
+            uint8_t r = src_row[x * 4 + 0], g = src_row[x * 4 + 1];
+            uint8_t b = src_row[x * 4 + 2], a = src_row[x * 4 + 3];
+
+            switch (format->id)
+            {
+                case WINED3DFMT_B8G8R8_UNORM:
+                    dst_row[x * 3 + 0] = b;
+                    dst_row[x * 3 + 1] = g;
+                    dst_row[x * 3 + 2] = r;
+                    break;
+
+                case WINED3DFMT_B5G6R5_UNORM:
+                    ((uint16_t *)dst_row)[x] = ((uint16_t)(r >> 3) << 11)
+                            | ((uint16_t)(g >> 2) << 5) | (b >> 3);
+                    break;
+
+                case WINED3DFMT_B5G5R5A1_UNORM:
+                case WINED3DFMT_B5G5R5X1_UNORM:
+                    ((uint16_t *)dst_row)[x] = (a >= 0x80 ? 0x8000 : 0)
+                            | ((uint16_t)(r >> 3) << 10) | ((uint16_t)(g >> 3) << 5) | (b >> 3);
+                    break;
+
+                case WINED3DFMT_B4G4R4A4_UNORM:
+                case WINED3DFMT_B4G4R4X4_UNORM:
+                    ((uint16_t *)dst_row)[x] = ((uint16_t)(a >> 4) << 12)
+                            | ((uint16_t)(r >> 4) << 8) | ((uint16_t)(g >> 4) << 4) | (b >> 4);
+                    break;
+
+                case WINED3DFMT_B2G3R3A8_UNORM:
+                    ((uint16_t *)dst_row)[x] = ((uint16_t)a << 8)
+                            | ((uint16_t)(r >> 5) << 5) | ((uint16_t)(g >> 5) << 2) | (b >> 6);
+                    break;
+
+                case WINED3DFMT_B10G10R10A2_UNORM:
+                    ((uint32_t *)dst_row)[x] = ((uint32_t)((a * 3 + 127) / 255) << 30)
+                            | ((uint32_t)((r * 1023 + 127) / 255) << 20)
+                            | ((uint32_t)((g * 1023 + 127) / 255) << 10)
+                            | ((uint32_t)((b * 1023 + 127) / 255));
+                    break;
+
+                case WINED3DFMT_R10G10B10A2_UNORM:
+                    ((uint32_t *)dst_row)[x] = ((uint32_t)((a * 3 + 127) / 255) << 30)
+                            | ((uint32_t)((b * 1023 + 127) / 255) << 20)
+                            | ((uint32_t)((g * 1023 + 127) / 255) << 10)
+                            | ((uint32_t)((r * 1023 + 127) / 255));
+                    break;
+
+                case WINED3DFMT_A8_UNORM:
+                    dst_row[x] = r;
+                    break;
+
+                case WINED3DFMT_L8_UNORM:
+                case WINED3DFMT_R8_UNORM:
+                    dst_row[x] = r;
+                    break;
+
+                case WINED3DFMT_L8A8_UNORM:
+                    ((uint16_t *)dst_row)[x] = (uint16_t)r | ((uint16_t)g << 8);
+                    break;
+
+                case WINED3DFMT_R16_UNORM:
+                    ((uint16_t *)dst_row)[x] = (uint16_t)r | ((uint16_t)r << 8);
+                    break;
+
+                case WINED3DFMT_B8G8R8A8_UNORM:
+                case WINED3DFMT_B8G8R8A8_UNORM_SRGB:
+                case WINED3DFMT_B8G8R8X8_UNORM:
+                case WINED3DFMT_B8G8R8X8_UNORM_SRGB:
+                    ((uint32_t *)dst_row)[x] = (uint32_t)b | ((uint32_t)g << 8)
+                            | ((uint32_t)r << 16) | ((uint32_t)a << 24);
+                    break;
+
+                case WINED3DFMT_R8G8B8A8_UNORM:
+                case WINED3DFMT_R8G8B8A8_UNORM_SRGB:
+                case WINED3DFMT_R8G8B8X8_UNORM:
+                    ((uint32_t *)dst_row)[x] = (uint32_t)r | ((uint32_t)g << 8)
+                            | ((uint32_t)b << 16) | ((uint32_t)a << 24);
+                    break;
+
+                default:
+                    break;
+            }
+        }
+    }
+
+    free(rgba);
+    return true;
+}
