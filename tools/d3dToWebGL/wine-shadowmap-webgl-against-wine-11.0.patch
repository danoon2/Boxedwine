+static void read_bgra8_pixels(const struct wined3d_gl_info *gl_info,
+        unsigned int x, unsigned int y, unsigned int width, unsigned int height, uint32_t *data)
+{
+    unsigned int i, pixel_count = width * height;
+    uint8_t *rgba;
+
+    if (!wined3d_settings.webgl)
+    {
+        gl_info->gl_ops.gl.p_glReadPixels(x, y, width, height,
+                GL_BGRA, GL_UNSIGNED_INT_8_8_8_8_REV, data);
+        return;
+    }
+
+    if (!(rgba = malloc(pixel_count * 4)))
+    {
+        ERR("Failed to allocate readback memory.\n");
+        return;
+    }
+
+    gl_info->gl_ops.gl.p_glReadPixels(x, y, width, height, GL_RGBA, GL_UNSIGNED_BYTE, rgba);
+    for (i = 0; i < pixel_count; ++i)
+    {
+        data[i] = (uint32_t)rgba[i * 4 + 2]
+                | ((uint32_t)rgba[i * 4 + 1] << 8)
+                | ((uint32_t)rgba[i * 4 + 0] << 16)
+                | ((uint32_t)rgba[i * 4 + 3] << 24);
+    }
+
+    free(rgba);
+}
