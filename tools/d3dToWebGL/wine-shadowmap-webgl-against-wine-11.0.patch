+
+/* Context activation is done by the caller. */
+void wined3d_context_gl_draw_shaded_quads(struct wined3d_context_gl *context_gl, struct wined3d_texture_gl *texture_gl,
+        unsigned int sub_resource_idx, const RECT *src_rects, const RECT *dst_rects, unsigned int quad_count,
+        enum wined3d_texture_filter_type filter)
+{
+    const struct wined3d_gl_info *gl_info = context_gl->gl_info;
+    struct wined3d_blt_info first_info, info;
+    struct blit_vertex
+    {
+        float x, y;
+        struct wined3d_vec3 texcoord;
+    } *vertices;
+    unsigned int level, vertex_count, i;
+    SIZE dst_size;
+    float left, right, top, bottom;
+
+    if (!quad_count)
+        return;
+
+    if (!gl_info->supported[ARB_VERTEX_BUFFER_OBJECT])
+    {
+        if (wined3d_settings.webgl)
+        {
+            ERR("Cannot draw batched blit quads without VBO support in WebGL-compatible profile.\n");
+            return;
+        }
+        for (i = 0; i < quad_count; ++i)
+            wined3d_context_gl_draw_shaded_quad(context_gl, texture_gl, sub_resource_idx,
+                    &src_rects[i], &dst_rects[i], filter);
+        return;
+    }
+
+    vertex_count = quad_count * 6;
+    if (!(vertices = malloc(vertex_count * sizeof(*vertices))))
+    {
+        ERR("Failed to allocate batched blit vertices.\n");
+        for (i = 0; i < quad_count; ++i)
+            wined3d_context_gl_draw_shaded_quad(context_gl, texture_gl, sub_resource_idx,
+                    &src_rects[i], &dst_rects[i], filter);
+        return;
+    }
+
+    texture2d_get_blt_info(texture_gl, sub_resource_idx, &src_rects[0], &first_info);
+    level = sub_resource_idx % texture_gl->t.level_count;
+    wined3d_context_gl_bind_texture(context_gl, first_info.bind_target, texture_gl->texture_rgb.name);
+    apply_texture_blit_state(gl_info, &texture_gl->texture_rgb, first_info.bind_target, level, filter);
+    gl_info->gl_ops.gl.p_glTexParameteri(first_info.bind_target, GL_TEXTURE_MAX_LEVEL, level);
+
+    wined3d_context_gl_pause_transform_feedback(context_gl, FALSE);
+    wined3d_context_gl_get_rt_size(context_gl, &dst_size);
+
+    for (i = 0; i < quad_count; ++i)
+    {
+        struct blit_vertex *v = &vertices[i * 6];
+
+        texture2d_get_blt_info(texture_gl, sub_resource_idx, &src_rects[i], &info);
+
+        left = dst_rects[i].left * 2.0f / dst_size.cx - 1.0f;
+        right = dst_rects[i].right * 2.0f / dst_size.cx - 1.0f;
+        top = dst_rects[i].top * 2.0f / dst_size.cy - 1.0f;
+        bottom = dst_rects[i].bottom * 2.0f / dst_size.cy - 1.0f;
+
+        v[0].x = left;
+        v[0].y = top;
+        v[0].texcoord = info.texcoords[0];
+        v[1].x = right;
+        v[1].y = top;
+        v[1].texcoord = info.texcoords[1];
+        v[2].x = left;
+        v[2].y = bottom;
+        v[2].texcoord = info.texcoords[2];
+        v[3] = v[2];
+        v[4] = v[1];
+        v[5].x = right;
+        v[5].y = bottom;
+        v[5].texcoord = info.texcoords[3];
+    }
+
+    if (!context_gl->blit_vbo)
+        GL_EXTCALL(glGenBuffers(1, &context_gl->blit_vbo));
+    GL_EXTCALL(glBindBuffer(GL_ARRAY_BUFFER, context_gl->blit_vbo));
+
+    wined3d_context_gl_unload_numbered_arrays(context_gl);
+
+    GL_EXTCALL(glBufferData(GL_ARRAY_BUFFER, vertex_count * sizeof(*vertices), vertices, GL_STREAM_DRAW));
+    GL_EXTCALL(glVertexAttribPointer(0, 2, GL_FLOAT, FALSE, sizeof(*vertices), NULL));
+    GL_EXTCALL(glVertexAttribPointer(1, 3, GL_FLOAT, FALSE, sizeof(*vertices),
+            (void *)FIELD_OFFSET(struct blit_vertex, texcoord)));
+
+    GL_EXTCALL(glEnableVertexAttribArray(0));
+    GL_EXTCALL(glEnableVertexAttribArray(1));
+
+    gl_info->gl_ops.gl.p_glDrawArrays(GL_TRIANGLES, 0, vertex_count);
+
+    GL_EXTCALL(glBindBuffer(GL_ARRAY_BUFFER, 0));
+    GL_EXTCALL(glDisableVertexAttribArray(1));
+    GL_EXTCALL(glDisableVertexAttribArray(0));
+    checkGLcall("batched draw");
+
+    gl_info->gl_ops.gl.p_glTexParameteri(first_info.bind_target, GL_TEXTURE_MAX_LEVEL, texture_gl->t.level_count - 1);
+    wined3d_context_gl_bind_texture(context_gl, first_info.bind_target, 0);
+    free(vertices);
+}
