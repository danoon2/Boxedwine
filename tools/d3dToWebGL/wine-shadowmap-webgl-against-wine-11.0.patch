+static HRESULT d3dx9_mesh_ensure_attribute_table(struct d3dx9_mesh *mesh)
+{
+    D3DXATTRIBUTERANGE *attrib_table;
+    DWORD attrib_table_size;
+    void *indices;
+    HRESULT hr;
+
+    if (mesh->attrib_table || mesh->attrib_table_size || !mesh->numfaces)
+        return D3D_OK;
+
+    attrib_table_size = count_attributes(mesh->attrib_buffer, mesh->numfaces);
+    if (!(attrib_table = calloc(attrib_table_size, sizeof(*attrib_table))))
+        return E_OUTOFMEMORY;
+
+    hr = IDirect3DIndexBuffer9_Lock(mesh->index_buffer, 0, 0, &indices, D3DLOCK_READONLY);
+    if (FAILED(hr))
+    {
+        free(attrib_table);
+        return hr;
+    }
+
+    fill_attribute_table(mesh->attrib_buffer, mesh->numfaces, indices,
+            mesh->options & D3DXMESH_32BIT, attrib_table);
+    IDirect3DIndexBuffer9_Unlock(mesh->index_buffer);
+
+    mesh->attrib_table = attrib_table;
+    mesh->attrib_table_size = attrib_table_size;
+
+    return D3D_OK;
+}
