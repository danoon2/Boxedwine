new file mode 100644
index 0000000..4299c3e
--- /dev/null
+++ b/BOXEDWINE_WEBGL_BUILD.md
@@ -0,0 +1,87 @@
+# BoxedWine WebGL Win32 DLL Build
+
+These instructions build the Wine DLLs used by the BoxedWine WebGL
+as true Win32 DLLs. This matters because a normal Wine build
+can produce Wine builtin PE DLLs; those DLLs may contain the marker
+`Wine builtin DLL` and do not behave the same in BoxedWine.
+
+- build native Wine tools first;
+- configure the DLL build with `--host=i686-w64-mingw32`;
+- pass `--disable-kernel32`;
+- define `USE_WIN32_OPENGL` and `USE_WIN32_VULKAN`;
+- link with `-static-libgcc`.
+
+## Prerequisites
+
+On Debian or Ubuntu, install the Wine build dependencies and MinGW:
+
+```sh
+sudo apt build-dep wine
+sudo apt install mingw-w64 git flex bison
+```
+
+The 32-bit build also needs enough 32-bit development packages for Wine's
+native tools configure step. If FreeType development files are not available,
+the script configures the tools build with `--without-freetype`.
+
+## Build
+
+From the top level of this Wine source checkout:
+
+```sh
+./build-boxedwine-webgl-dlls.sh
+```
+
+By default, the script writes build intermediates to:
+
+```text
+../boxedwine-webgl-wine-build
+```
+
+and copies the final DLLs to:
+
+```text
+../boxedwine-webgl-wine-build/boxedwine-webgl-dlls
+```
+
+To choose a different build directory:
+
+```sh
+./build-boxedwine-webgl-dlls.sh --build-dir /tmp/boxedwine-webgl-wine-build
+```
+
+To choose the parallelism:
+
+```sh
+./build-boxedwine-webgl-dlls.sh --jobs 8
+```
+
+## Outputs
+
+The script builds and stages these DLLs:
+
+- `d3d8.dll`
+- `d3d9.dll`
+- `dxgi.dll`
+- `d3dx9_43.dll`
+- `d3dxof.dll`
+- `wined3d.dll`
+
+It also prints each file's size and SHA-256 hash at the end.
+
+## Sanity Checks
+
+After a successful build, verify that `d3d9.dll` does not contain the builtin
+marker:
+
+```sh
+strings ../boxedwine-webgl-wine-build/boxedwine-webgl-dlls/d3d9.dll | grep 'Wine builtin DLL'
+```
+
+That command should print nothing.
+
+You can also confirm that `d3d9.dll` imports `wined3d.dll`:
+
+```sh
+i686-w64-mingw32-objdump -p ../boxedwine-webgl-wine-build/boxedwine-webgl-dlls/d3d9.dll | grep 'DLL Name'
+```
diff --git a/build-boxedwine-webgl-dlls.sh b/build-boxedwine-webgl-dlls.sh
new file mode 100755
index 0000000..40b58db
--- /dev/null
+++ b/build-boxedwine-webgl-dlls.sh
@@ -0,0 +1,151 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+usage() {
+    cat <<'EOF'
+Usage: ./build-boxedwine-webgl-dlls.sh [options]
+
+Build true Win32 Wine DLLs for BoxedWine WebGL.
+
+Options:
+  --build-dir DIR   Build/output directory.
+                    Default: ../boxedwine-webgl-wine-build
+  --jobs N          Parallel make jobs. Default: detected CPU count.
+  --help            Show this help.
+
+Outputs:
+  DIR/boxedwine-webgl-dlls/{d3d8,d3d9,dxgi,d3dx9_43,d3dxof,wined3d}.dll
+EOF
+}
+
+script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+build_dir="$(cd "$script_dir/.." && pwd)/boxedwine-webgl-wine-build"
+jobs="$(getconf _NPROCESSORS_ONLN 2>/dev/null || nproc 2>/dev/null || echo 1)"
+
+while [ "$#" -gt 0 ]; do
+    case "$1" in
+        --build-dir)
+            if [ "$#" -lt 2 ]; then
+                echo "error: --build-dir requires a value" >&2
+                exit 2
+            fi
+            build_dir="$2"
+            shift 2
+            ;;
+        --jobs)
+            if [ "$#" -lt 2 ]; then
+                echo "error: --jobs requires a value" >&2
+                exit 2
+            fi
+            jobs="$2"
+            shift 2
+            ;;
+        --help|-h)
+            usage
+            exit 0
+            ;;
+        *)
+            echo "error: unknown option '$1'" >&2
+            usage >&2
+            exit 2
+            ;;
+    esac
+done
+
+case "$jobs" in
+    ''|*[!0-9]*)
+        echo "error: --jobs must be a positive integer" >&2
+        exit 2
+        ;;
+    0)
+        echo "error: --jobs must be greater than zero" >&2
+        exit 2
+        ;;
+esac
+
+require_tool() {
+    if ! command -v "$1" >/dev/null 2>&1; then
+        echo "error: required tool '$1' was not found in PATH" >&2
+        exit 1
+    fi
+}
+
+require_tool make
+require_tool gcc
+require_tool i686-w64-mingw32-gcc
+require_tool i686-w64-mingw32-objdump
+require_tool sha256sum
+
+wine_tools_dir="$build_dir/wine-tools"
+wine_win32_dir="$build_dir/wine-win32"
+output_dir="$build_dir/boxedwine-webgl-dlls"
+
+echo "Wine source: $script_dir"
+echo "Build dir:   $build_dir"
+echo "Jobs:        $jobs"
+
+mkdir -p "$wine_tools_dir" "$wine_win32_dir" "$output_dir"
+
+echo
+echo "Configuring native Wine tools..."
+(
+    cd "$wine_tools_dir"
+    "$script_dir/configure" --without-x --without-freetype
+)
+
+echo
+echo "Building native Wine tools..."
+make -C "$wine_tools_dir" -j"$jobs"
+
+echo
+echo "Configuring true Win32 DLL build..."
+(
+    cd "$wine_win32_dir"
+    "$script_dir/configure" \
+        --without-x \
+        --disable-kernel32 \
+        --disable-tests \
+        --without-freetype \
+        --host=i686-w64-mingw32 \
+        CFLAGS="-O3 -DWINE_NOWINSOCK -DUSE_WIN32_OPENGL -DUSE_WIN32_VULKAN" \
+        --with-wine-tools="$wine_tools_dir/" \
+        LDFLAGS=" -static-libgcc"
+)
+
+echo
+echo "Building DLLs..."
+make -C "$wine_win32_dir" -j"$jobs" \
+    dlls/wined3d/wined3d.dll \
+    dlls/d3d9/d3d9.dll \
+    dlls/d3d8/d3d8.dll \
+    dlls/dxgi/dxgi.dll \
+    dlls/d3dx9_43/d3dx9_43.dll \
+    dlls/d3dxof/d3dxof.dll
+
+echo
+echo "Copying DLLs to $output_dir..."
+cp -f "$wine_win32_dir/dlls/wined3d/wined3d.dll" "$output_dir/"
+cp -f "$wine_win32_dir/dlls/d3d9/d3d9.dll" "$output_dir/"
+cp -f "$wine_win32_dir/dlls/d3d8/d3d8.dll" "$output_dir/"
+cp -f "$wine_win32_dir/dlls/dxgi/dxgi.dll" "$output_dir/"
+cp -f "$wine_win32_dir/dlls/d3dx9_43/d3dx9_43.dll" "$output_dir/"
+cp -f "$wine_win32_dir/dlls/d3dxof/d3dxof.dll" "$output_dir/"
+
+echo
+echo "Build output:"
+for dll in d3d8.dll d3d9.dll dxgi.dll d3dx9_43.dll d3dxof.dll wined3d.dll; do
+    path="$output_dir/$dll"
+    printf "%-14s %10s " "$dll" "$(stat -c %s "$path")"
+    sha256sum "$path" | awk '{print $1}'
+done
+
+echo
+if strings "$output_dir/d3d9.dll" | grep -q "Wine builtin DLL"; then
+    echo "warning: d3d9.dll contains 'Wine builtin DLL'; this is not the expected true Win32 output." >&2
+else
+    echo "Sanity check passed: d3d9.dll does not contain 'Wine builtin DLL'."
+fi
+
+echo
+echo "d3d9.dll imports:"
+i686-w64-mingw32-objdump -p "$output_dir/d3d9.dll" | grep "DLL Name" || true
